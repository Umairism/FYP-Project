# HealSense Mobile App Environment Variables

# Backend API
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1
EXPO_PUBLIC_WS_URL=ws://localhost:5000/ws

# Real-time update interval (milliseconds)
EXPO_PUBLIC_POLLING_INTERVAL=5000

# Enable mock data for development
EXPO_PUBLIC_USE_MOCK_DATA=true

# Notification settings
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true

# App settings
EXPO_PUBLIC_APP_NAME=HealSense
EXPO_PUBLIC_APP_VERSION=0.0.1
