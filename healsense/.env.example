# HealSense root environment template
# Copy this file to .env and fill in the values you want to use locally.

# Core application
PROJECT_NAME=HealSense
ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=5000
LOG_LEVEL=INFO

# Security
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALLOWED_ORIGINS=*

# Database
DATABASE_URL=postgresql+asyncpg://healsense_user:healsense_password@localhost:5432/healsense_db

# Email / SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password_here
MAIL_DEFAULT_SENDER=your_email@gmail.com

# Redis / cache
REDIS_HOST=localhost
REDIS_PORT=6379

# MQTT / IoT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=healsense/vitals

# Firebase / server integration
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# AI provider keys
OPENAI_API_KEY=
GEMINI_API_KEY=

# AI / ML model paths
LSTM_MODEL_PATH=data/models/lstm_model.h5
RF_MODEL_PATH=data/models/random_forest.pkl
SCALER_PATH=data/models/scaler.pkl
CNN_MODEL_PATH=data/models/cnn_model.h5
TFLITE_MODEL_PATH=data/models/model.tflite

# Alert thresholds
HEART_RATE_MIN=50
HEART_RATE_MAX=120
SPO2_MIN=92
TEMP_MAX=38.0

# WhatsApp / SMS
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID/messages
WHATSAPP_API_TOKEN=
WHATSAPP_TEMPLATE_ALERT=health_alert
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Backend realtime / deployment
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10
CORS_ORIGINS=*

# Web app (Vite)
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_WS_URL=ws://localhost:5000/ws
VITE_POLLING_INTERVAL=5000
VITE_USE_MOCK_DATA=true

# Kaggle / datasets
KAGGLE_API_TOKEN=your_kaggle_api_token_here
