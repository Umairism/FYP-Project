# Kaggle API Configuration
# Get your token from: https://www.kaggle.com/account
KAGGLE_API_TOKEN=your_kaggle_api_token_here

# AI API Keys (Choose one or both)
# OpenAI: Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Google Gemini: Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://healsense_user:healsense_password@localhost:5432/healsense_db

# Security Settings
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secure_secret_key_here

# Flask Configuration
FLASK_ENV=development
DEBUG=True

# Email Configuration (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password_here

# Optional: WhatsApp API (if using)
WHATSAPP_API_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER=your_phone_number_here
