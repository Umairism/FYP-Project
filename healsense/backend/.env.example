# HealSense Backend (FastAPI) — Environment Variables
# Copy this file to .env and set secure values for production.

# App
PROJECT_NAME=HealSense
ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=5000

# Security
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALLOWED_ORIGINS=*

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/healsense

# Email / SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password_here
MAIL_DEFAULT_SENDER=your_email@gmail.com

# Cache/Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# MQTT (optional)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=healsense/vitals

# Firebase (server-side, optional)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ML model paths
LSTM_MODEL_PATH=data/models/lstm_model.h5
RF_MODEL_PATH=data/models/random_forest.pkl
SCALER_PATH=data/models/scaler.pkl

# Alert thresholds (defaults)
HEART_RATE_MIN=50
HEART_RATE_MAX=120
SPO2_MIN=92
TEMP_MAX=38.0

# WhatsApp Business API (optional)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID/messages
WHATSAPP_API_TOKEN=
WHATSAPP_TEMPLATE_ALERT=health_alert

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Logging
LOG_LEVEL=INFO
